# 墨渊 (Moyuan) - 多模态个人知识库
#
# 环境变量模板，复制为 .env 后填写实际值

# 数据库
# 示例: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/moyuan
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/moyuan

# 文件存储
FILE_STORAGE_ROOT=../data/files

# 加密密钥 (用于 API Key 加密存储)
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-with-fernet

# AI 提供商（可选，可在 Web UI 中配置）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# TENCENT_SECRET_ID=xxx
# TENCENT_SECRET_KEY=xxx

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=false
